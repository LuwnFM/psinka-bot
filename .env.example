# 🔑 Discord Bot Token
# Получите на: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# 🔮 OpenRouter API Key (опционально)
# Получите на: https://openrouter.ai/keys
OPENR_TOKEN=your_openrouter_token_here

# 🐦 Groq Cloud API Key (опционально, но рекомендуется)
# Получите на: https://console.groq.com/keys
GROQ_TOKEN=your_groq_token_here

# ⚙️ Настройки производительности
# Для Railway ставьте 2-3, для локального теста можно 10+
MAX_CONCURRENT=2

# 🧪 Режим отладки (опционально)
DEBUG=false

# 🚂 Флаг Railway (автоматически задаётся на сервере)
# RAILWAY=true